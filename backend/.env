# ─────────────────────────────────────────────────────────────
# SyncNode Backend – Environment Configuration
# Copy this file and fill in every value before deploying.
# NEVER commit the filled-in version to git.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Local SQLite (dev/testing only – NOT recommended for prod):
#   DATABASE_URL=sqlite:///./sql_app.db
#
# Production PostgreSQL (Render, Railway, Supabase, Neon …):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#
# WHERE TO GET IT:
#   • Render   → Dashboard → Your PostgreSQL service → "Connection String" tab
#   • Railway  → Project → PostgreSQL plugin → "Connect" tab → "DATABASE_URL"
#   • Supabase → Project → Settings → Database → "Connection string" (URI mode)
#   • Neon     → Project → Dashboard → "Connection string"
DATABASE_URL=sqlite:///./sql_app.db

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URL once you have it, e.g.:
#   CORS_ORIGINS=https://syncnode.vercel.app,http://localhost:3000
#
# WHERE TO GET IT:
#   After deploying on Vercel, the URL is shown on the project dashboard
#   (e.g. https://your-app-name.vercel.app). Add it here exactly as-is.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
